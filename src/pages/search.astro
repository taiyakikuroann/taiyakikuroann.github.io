---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Search | kuroann.memo" description="Search articles by keyword.">
  <div class="container search-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> &gt; <span>Search</span>
    </nav>

    <div class="page-header">
      <h1 class="page-title font-heading">
        Search <span class="gradient-text">Articles</span>
      </h1>
      <p class="page-description">
        ブログおよび Wiki 記事からキーワード検索を行います。
      </p>
    </div>

    <!-- Search Input Area -->
    <div class="search-box glass-card">
      <div class="search-input-wrapper">
        <span class="search-icon">🔍</span>
        <input 
          type="text" 
          id="search-input" 
          placeholder="キーワードを入力... (例: OpenTelemetry, Terraform)" 
          autocomplete="off"
          autofocus
        />
        <button id="clear-btn" class="clear-btn" aria-label="Clear search">&times;</button>
      </div>
    </div>

    <!-- Search Results -->
    <div class="search-results-section">
      <h2 class="results-heading font-heading">
        Results (<span id="results-count">0</span>)
      </h2>
      <div id="results-list" class="cards-list">
        <!-- Results will be injected here by JavaScript -->
        <p class="loading-text">検索インデックスを読み込み中...</p>
      </div>
    </div>
  </div>
</Layout>

<script>
  interface SearchItem {
    slug: string;
    title: string;
    description: string;
    tags: string[];
    type: 'blog' | 'wiki';
    category: string;
    url: string;
  }

  let searchIndex: SearchItem[] = [];
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const resultsList = document.getElementById('results-list');
  const resultsCount = document.getElementById('results-count');
  const clearBtn = document.getElementById('clear-btn');

  // Load search index
  async function loadSearchIndex() {
    try {
      const response = await fetch('/search-index.json');
      if (!response.ok) throw new Error('Failed to load search index');
      searchIndex = await response.json();
      
      // Initialize search with query param if present
      const urlParams = new URLSearchParams(window.location.search);
      const query = urlParams.get('q') || '';
      if (query) {
        searchInput.value = query;
      }
      
      performSearch(query);
    } catch (error) {
      console.error(error);
      if (resultsList) {
        resultsList.innerHTML = '<p class="error-text">検索インデックスの読み込みに失敗しました。</p>';
      }
    }
  }

  // Escape HTML to prevent XSS
  function escapeHTML(str: string) {
    return str.replace(/[&<>'"]/g, 
      tag => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        "'": '&#39;',
        '"': '&quot;'
      }[tag] || tag)
    );
  }

  // Highlight search keywords
  function highlightText(text: string, query: string): string {
    if (!query) return escapeHTML(text);
    const escapedText = escapeHTML(text);
    const escapedQuery = escapeHTML(query).replace(/[-\/\\^$*+?.()|[\]{}]/g, '\\$&'); // escape regex chars
    const regex = new RegExp(`(${escapedQuery})`, 'gi');
    return escapedText.replace(regex, '<mark class="highlight">$1</mark>');
  }

  // Perform search and render results
  function performSearch(query: string) {
    const trimmedQuery = query.trim().toLowerCase();
    
    // Toggle clear button
    if (clearBtn) {
      clearBtn.style.display = trimmedQuery ? 'block' : 'none';
    }

    if (!resultsList || !resultsCount) return;

    // Filter posts
    const results = searchIndex.filter(item => {
      if (!trimmedQuery) return true; // Show all if empty
      
      return (
        item.title.toLowerCase().includes(trimmedQuery) ||
        item.description.toLowerCase().includes(trimmedQuery) ||
        item.tags.some(tag => tag.toLowerCase().includes(trimmedQuery)) ||
        item.category.toLowerCase().includes(trimmedQuery)
      );
    });

    resultsCount.textContent = results.length.toString();

    if (results.length === 0) {
      resultsList.innerHTML = '<p class="no-content">該当する記事が見つかりませんでした。</p>';
      return;
    }

    // Render results
    resultsList.innerHTML = results.map(item => {
      const typeClass = item.type === 'blog' ? 'blog-badge' : 'wiki-badge';
      const highlightedTitle = highlightText(item.title, trimmedQuery);
      const highlightedDesc = highlightText(item.description, trimmedQuery);

      const tagElements = item.tags.map(tag => {
        const isMatch = trimmedQuery && tag.toLowerCase().includes(trimmedQuery);
        const tagClass = isMatch ? 'card-tag active-tag' : 'card-tag';
        return `<a href="/tags/${encodeURIComponent(tag)}" class="${tagClass}">#${escapeHTML(tag)}</a>`;
      }).join(' ');

      return `
        <div class="glass-card content-card-wrapper">
          <a href="${escapeHTML(item.url)}" class="content-card">
            <div class="card-meta">
              <span class="type-badge ${typeClass}">${escapeHTML(item.category)}</span>
            </div>
            <h3 class="card-title font-heading">${highlightedTitle}</h3>
            <p class="card-desc">${highlightedDesc}</p>
          </a>
          <div class="card-tags">
            ${tagElements}
          </div>
        </div>
      `;
    }).join('');
  }

  // Listeners
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      const query = (e.target as HTMLInputElement).value;
      
      // Update URL query parameter without reloading
      const url = new URL(window.location.href);
      if (query) {
        url.searchParams.set('q', query);
      } else {
        url.searchParams.delete('q');
      }
      window.history.replaceState({}, '', url.toString());

      performSearch(query);
    });
  }

  if (clearBtn && searchInput) {
    clearBtn.addEventListener('click', () => {
      searchInput.value = '';
      searchInput.focus();
      
      const url = new URL(window.location.href);
      url.searchParams.delete('q');
      window.history.replaceState({}, '', url.toString());

      performSearch('');
    });
  }

  // Initial load
  loadSearchIndex();
</script>

<style>
  .breadcrumb {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .breadcrumb a {
    color: var(--accent-blue);
  }

  .breadcrumb a:hover {
    color: var(--text-primary);
  }

  .page-header {
    margin-bottom: 30px;
    border-left: 4px solid var(--accent-purple);
    padding-left: 20px;
  }

  .page-title {
    font-size: 2.2rem;
    margin-bottom: 8px;
  }

  .page-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .search-box {
    padding: 16px 20px;
    margin-bottom: 40px;
  }

  .search-input-wrapper {
    display: flex;
    align-items: center;
    position: relative;
  }

  .search-icon {
    font-size: 1.25rem;
    margin-right: 12px;
    color: var(--text-muted);
  }

  #search-input {
    width: 100%;
    border: none;
    background: transparent;
    color: var(--text-primary);
    font-size: 1.1rem;
    outline: none;
    padding: 4px 0;
  }

  #search-input::placeholder {
    color: var(--text-muted);
  }

  .clear-btn {
    display: none;
    background: transparent;
    border: none;
    color: var(--text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    padding: 0 8px;
    line-height: 1;
    transition: var(--transition-smooth);
  }

  .clear-btn:hover {
    color: var(--text-primary);
  }

  .search-results-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .results-heading {
    font-size: 1.3rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-muted);
    padding-bottom: 10px;
  }

  .cards-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .cards-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  .loading-text, .error-text, .no-content {
    grid-column: 1 / -1;
    color: var(--text-muted);
    font-size: 0.95rem;
    text-align: center;
    padding: 40px 20px;
    border: 1px dashed var(--border-muted);
    border-radius: 12px;
  }

  .error-text {
    color: #ff5252;
    border-color: #ff525233;
  }

  /* Card custom styling */
  :global(.content-card-wrapper) {
    display: flex;
    flex-direction: column;
    padding: 20px;
    height: 100%;
  }

  :global(.content-card) {
    display: flex;
    flex-direction: column;
    gap: 12px;
    text-decoration: none;
    flex-grow: 1;
    margin-bottom: 12px;
  }

  :global(.card-meta) {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  :global(.type-badge) {
    font-size: 0.75rem;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
  }

  :global(.blog-badge) {
    background: rgba(160, 50, 255, 0.1);
    border: 1px solid var(--accent-purple);
    color: var(--accent-purple);
  }

  :global(.wiki-badge) {
    background: rgba(0, 150, 255, 0.1);
    border: 1px solid var(--accent-blue);
    color: var(--accent-blue);
  }

  :global(.card-title) {
    font-size: 1.15rem;
    color: var(--text-primary);
    transition: var(--transition-smooth);
  }

  :global(.content-card:hover .card-title) {
    color: var(--accent-purple);
  }

  :global(.card-desc) {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  :global(.card-tags) {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    border-top: 1px solid var(--border-muted);
    padding-top: 10px;
    margin-top: auto;
  }

  :global(.card-tag) {
    font-size: 0.75rem;
    color: var(--accent-blue);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  :global(.card-tag:hover) {
    color: var(--text-primary);
  }

  :global(.active-tag) {
    color: var(--accent-purple);
    font-weight: 700;
  }

  /* Highlight class */
  :global(.highlight) {
    background: rgba(255, 235, 59, 0.25);
    color: #ffd54f;
    border-bottom: 2px solid #ffd54f;
    padding: 0 2px;
    border-radius: 2px;
  }
</style>
