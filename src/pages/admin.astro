---
import Layout from '../layouts/Layout.astro';

// 開発環境以外でアクセスされた場合の防御（念のためビルド除外漏れ時）
if (import.meta.env.PROD) {
  return Astro.redirect('/');
}
---

<Layout title="Admin Dashboard | kuroann.memo" description="Create new blog posts and wiki articles locally.">
  <div class="container admin-page">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> &gt; <span>Admin Dashboard</span>
    </nav>

    <div class="page-header">
      <h1 class="page-title font-heading">
        Admin <span class="gradient-text">Dashboard</span>
      </h1>
      <p class="page-description">
        新しいブログ記事、または Wiki 記事をローカル環境で簡単に追加できます。
      </p>
    </div>

    <!-- Alert Message Area -->
    <div id="alert-box" class="alert-box" style="display: none;">
      <span id="alert-message"></span>
    </div>

    <!-- Form Area -->
    <div class="glass-card form-container">
      <form id="create-post-form" class="admin-form">
        <!-- Content Type Selection -->
        <div class="form-group row-group">
          <label>種別</label>
          <div class="radio-group">
            <label class="radio-label">
              <input type="radio" name="type" value="blog" checked />
              <span>Blog (ブログ)</span>
            </label>
            <label class="radio-label">
              <input type="radio" name="type" value="wiki" />
              <span>Wiki (技術メモ)</span>
            </label>
          </div>
        </div>

        <!-- Title -->
        <div class="form-group">
          <label for="title">タイトル</label>
          <input type="text" id="title" required placeholder="記事のタイトルを入力..." />
        </div>

        <!-- Slug -->
        <div class="form-group">
          <label for="slug">スラッグ (URLパス・ファイル名)</label>
          <input 
            type="text" 
            id="slug" 
            required 
            placeholder="例: learn-opentelemetry (半角英数字、ハイフン、アンダースコアのみ)" 
            pattern="^[a-z0-9-_]+$"
          />
          <small class="help-text">`src/content/[blog/wiki]/[slug].md` として保存されます。</small>
        </div>

        <!-- Description -->
        <div class="form-group">
          <label for="description">説明 (description)</label>
          <input type="text" id="description" placeholder="記事の短い要約を入力..." />
        </div>

        <!-- Category (Wiki Only) -->
        <div id="category-group" class="form-group" style="display: none;">
          <label for="category">カテゴリ</label>
          <input type="text" id="category" placeholder="例: GCP, Git, Kubernetes, Frontend" />
        </div>

        <!-- Tags -->
        <div class="form-group">
          <label for="tags">タグ (カンマ区切り)</label>
          <input type="text" id="tags" placeholder="例: OpenTelemetry, GCP, SRE (カンマで区切ってください)" />
        </div>

        <!-- Draft Checkbox -->
        <div class="form-group checkbox-group">
          <label class="checkbox-label">
            <input type="checkbox" id="draft" checked />
            <span>下書き保存 (draft: true)</span>
          </label>
        </div>

        <!-- Content Area -->
        <div class="form-group">
          <label for="content">本文 (Markdown 形式)</label>
          <textarea id="content" rows="15" required placeholder="Markdown 形式で記事の内容を入力してください..."></textarea>
        </div>

        <!-- Submit Button -->
        <div class="form-actions">
          <button type="submit" id="submit-btn" class="submit-btn font-heading">
            記事を作成する
          </button>
        </div>
      </form>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('create-post-form') as HTMLFormElement;
  const typeRadios = document.getElementsByName('type') as NodeListOf<HTMLInputElement>;
  const categoryGroup = document.getElementById('category-group');
  const alertBox = document.getElementById('alert-box');
  const alertMessage = document.getElementById('alert-message');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const titleInput = document.getElementById('title') as HTMLInputElement;
  const slugInput = document.getElementById('slug') as HTMLInputElement;

  // Toggle Category input visibility based on content type
  typeRadios.forEach(radio => {
    radio.addEventListener('change', (e) => {
      if (categoryGroup) {
        categoryGroup.style.display = (e.target as HTMLInputElement).value === 'wiki' ? 'block' : 'none';
        const categoryInput = document.getElementById('category') as HTMLInputElement;
        if ((e.target as HTMLInputElement).value === 'wiki') {
          categoryInput.setAttribute('required', 'true');
        } else {
          categoryInput.removeAttribute('required');
        }
      }
    });
  });

  // Simple auto-slug helper based on title (converts alphanumeric and hyphens)
  titleInput.addEventListener('blur', () => {
    if (!slugInput.value && titleInput.value) {
      slugInput.value = titleInput.value
        .toLowerCase()
        .replace(/[^a-z0-9\s-_]/g, '') // remove symbols
        .replace(/\s+/g, '-'); // replace spaces with hyphens
    }
  });

  function showAlert(message: string, isError = false) {
    if (alertBox && alertMessage) {
      alertBox.className = `alert-box ${isError ? 'error-alert' : 'success-alert'}`;
      alertMessage.textContent = message;
      alertBox.style.display = 'block';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  }

  // Handle Form Submission
  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const type = (document.querySelector('input[name="type"]:checked') as HTMLInputElement).value;
    const title = (document.getElementById('title') as HTMLInputElement).value;
    const slug = (document.getElementById('slug') as HTMLInputElement).value;
    const description = (document.getElementById('description') as HTMLInputElement).value;
    const category = (document.getElementById('category') as HTMLInputElement).value;
    const tags = (document.getElementById('tags') as HTMLInputElement).value;
    const draft = (document.getElementById('draft') as HTMLInputElement).checked;
    const content = (document.getElementById('content') as HTMLTextAreaElement).value;

    submitBtn.disabled = true;
    submitBtn.textContent = '保存処理中...';

    try {
      const response = await fetch('/api/create-post', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          title,
          slug,
          description,
          category,
          tags,
          draft,
          content,
          type
        })
      });

      const result = await response.json();

      if (!response.ok) {
        throw new Error(result.error || '不明なエラーが発生しました');
      }

      showAlert(`作成に成功しました！保存先: ${result.path}`);
      form.reset();
      if (categoryGroup) {
        categoryGroup.style.display = 'none';
      }
    } catch (err: any) {
      showAlert(err.message || '保存に失敗しました', true);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = '記事を作成する';
    }
  });
</script>

<style>
  .breadcrumb {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .breadcrumb a {
    color: var(--accent-blue);
  }

  .breadcrumb a:hover {
    color: var(--text-primary);
  }

  .page-header {
    margin-bottom: 30px;
    border-left: 4px solid var(--accent-purple);
    padding-left: 20px;
  }

  .page-title {
    font-size: 2.2rem;
    margin-bottom: 8px;
  }

  .page-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  /* Form container card styling */
  .form-container {
    padding: 30px;
    margin-bottom: 40px;
  }

  .admin-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .row-group {
    flex-direction: row;
    align-items: center;
    gap: 24px;
  }

  .form-group label {
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  .form-group input[type="text"],
  .form-group textarea {
    width: 100%;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--border-muted);
    border-radius: 8px;
    color: var(--text-primary);
    padding: 10px 14px;
    font-size: 1rem;
    outline: none;
    transition: var(--transition-smooth);
  }

  .form-group input[type="text"]:focus,
  .form-group textarea:focus {
    border-color: var(--accent-purple);
    box-shadow: 0 0 8px rgba(160, 50, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
  }

  .help-text {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: -2px;
  }

  /* Radio and checkbox styles */
  .radio-group {
    display: flex;
    gap: 20px;
  }

  .radio-label, .checkbox-label {
    display: flex;
    align-items: center;
    gap: 8px;
    cursor: pointer;
    font-weight: 500 !important;
  }

  .radio-label input[type="radio"],
  .checkbox-label input[type="checkbox"] {
    width: 16px;
    height: 16px;
    accent-color: var(--accent-purple);
  }

  .checkbox-group {
    margin: 8px 0;
  }

  /* Submit button */
  .form-actions {
    margin-top: 10px;
  }

  .submit-btn {
    background: linear-gradient(135deg, var(--accent-purple), var(--accent-blue));
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 12px 24px;
    font-size: 1.05rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-smooth);
    width: 100%;
  }

  @media (min-width: 768px) {
    .submit-btn {
      width: auto;
    }
  }

  .submit-btn:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(160, 50, 255, 0.4);
  }

  .submit-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  /* Alert styles */
  .alert-box {
    padding: 14px 20px;
    border-radius: 8px;
    margin-bottom: 24px;
    font-weight: 500;
  }

  .success-alert {
    background: rgba(76, 175, 80, 0.15);
    border: 1px solid #4caf50;
    color: #4caf50;
  }

  .error-alert {
    background: rgba(244, 67, 54, 0.15);
    border: 1px solid #f44336;
    color: #f44336;
  }
</style>
