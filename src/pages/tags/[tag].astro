---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const allBlogPosts = await getCollection('blog', ({ data }) => !data.draft);
  const allWikiPosts = await getCollection('wiki', ({ data }) => !data.draft);

  // すべてのユニークなタグを抽出
  const tags = new Set<string>();
  allBlogPosts.forEach(post => post.data.tags?.forEach(tag => tags.add(tag)));
  allWikiPosts.forEach(post => post.data.tags?.forEach(tag => tags.add(tag)));

  return Array.from(tags).map((tag) => {
    // 該当するタグを持つポストを抽出
    const filteredBlog = allBlogPosts.filter(post => post.data.tags?.includes(tag));
    const filteredWiki = allWikiPosts.filter(post => post.data.tags?.includes(tag));
    return {
      params: { tag },
      props: { 
        tag,
        blogPosts: filteredBlog,
        wikiPosts: filteredWiki
      },
    };
  });
}

const { tag, blogPosts, wikiPosts } = Astro.props;

const formatDate = (date: Date) => {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  });
};
---

<Layout title={`Tag: #${tag} | kuroann.memo`} description={`Articles tagged with #${tag}`}>
  <div class="container tag-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> &gt; <span>Tag: #{tag}</span>
    </nav>

    <div class="page-header">
      <h1 class="page-title font-heading">
        Tag: <span class="gradient-text">#{tag}</span>
      </h1>
      <p class="page-description">
        「#{tag}」タグが紐づいた記事の一覧です。（ブログ: {blogPosts.length}件、Wiki: {wikiPosts.length}件）
      </p>
    </div>

    <div class="tag-results">
      <!-- Blog section -->
      {blogPosts.length > 0 && (
        <section class="results-section">
          <h2 class="section-title font-heading">✍️ Blog Posts</h2>
          <div class="cards-list">
            {blogPosts.map((post) => (
              <div class="glass-card content-card-wrapper">
                <a href={`/blog/${post.slug}`} class="content-card">
                  <div class="card-meta">
                    <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
                  </div>
                  <h3 class="card-title font-heading">{post.data.title}</h3>
                  <p class="card-desc">{post.data.description}</p>
                </a>
                <div class="card-tags">
                  {post.data.tags.map(t => (
                    <a href={`/tags/${t}`} class={`card-tag ${t === tag ? 'active-tag' : ''}`}>#{t}</a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      <!-- Wiki section -->
      {wikiPosts.length > 0 && (
        <section class="results-section">
          <h2 class="section-title font-heading">📚 Wiki Articles</h2>
          <div class="cards-list">
            {wikiPosts.map((wiki) => (
              <div class="glass-card content-card-wrapper">
                <a href={`/wiki/${wiki.slug}`} class="content-card">
                  <div class="card-meta">
                    <span class="wiki-category">{wiki.data.category}</span>
                    <time datetime={wiki.data.updatedDate.toISOString()}>Update: {formatDate(wiki.data.updatedDate)}</time>
                  </div>
                  <h3 class="card-title font-heading">{wiki.data.title}</h3>
                  <p class="card-desc">{wiki.data.description}</p>
                </a>
                <div class="card-tags">
                  {wiki.data.tags.map(t => (
                    <a href={`/tags/${t}`} class={`card-tag ${t === tag ? 'active-tag' : ''}`}>#{t}</a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )}

      {blogPosts.length === 0 && wikiPosts.length === 0 && (
        <div class="no-content">
          <p>該当する記事が見つかりませんでした。</p>
        </div>
      )}
    </div>
  </div>
</Layout>

<style>
  .breadcrumb {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .breadcrumb a {
    color: var(--accent-blue);
  }

  .breadcrumb a:hover {
    color: var(--text-primary);
  }

  .page-header {
    margin-bottom: 40px;
    border-left: 4px solid var(--accent-blue);
    padding-left: 20px;
  }

  .page-title {
    font-size: 2.2rem;
    margin-bottom: 8px;
  }

  .page-description {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .tag-results {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .results-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .section-title {
    font-size: 1.5rem;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-muted);
    padding-bottom: 10px;
  }

  .cards-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .cards-list {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Card custom styling */
  .content-card-wrapper {
    display: flex;
    flex-direction: column;
    padding: 20px;
    height: 100%;
  }

  .content-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    text-decoration: none;
    flex-grow: 1;
    margin-bottom: 12px;
  }

  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .card-title {
    font-size: 1.15rem;
    color: var(--text-primary);
    transition: var(--transition-smooth);
  }

  .content-card:hover .card-title {
    color: var(--accent-purple);
  }

  .card-desc {
    color: var(--text-secondary);
    font-size: 0.9rem;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    border-top: 1px solid var(--border-muted);
    padding-top: 10px;
    margin-top: auto;
  }

  .card-tag {
    font-size: 0.75rem;
    color: var(--accent-blue);
    text-decoration: none;
    transition: var(--transition-smooth);
  }

  .card-tag:hover {
    color: var(--text-primary);
  }

  .active-tag {
    color: var(--accent-purple);
    font-weight: 700;
  }

  .wiki-category {
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--bg-tertiary);
    padding: 2px 8px;
    border-radius: 4px;
  }

  .no-content {
    color: var(--text-muted);
    font-size: 0.9rem;
    text-align: center;
    padding: 24px;
    border: 1px dashed var(--border-muted);
    border-radius: 12px;
  }
</style>
