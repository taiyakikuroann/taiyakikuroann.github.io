---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const wikiPosts = await getCollection('wiki', ({ data }) => !data.draft);
  return wikiPosts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formatDate = (date: Date) => {
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  });
};
---

<Layout title={`${post.data.title} | Wiki`} description={post.data.description}>
  <article class="wiki-post container">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a> &gt; <a href="/wiki">Wiki</a> &gt; <span>{post.data.title}</span>
    </nav>

    <!-- Header info -->
    <header class="post-header">
      <div class="post-meta">
        <span class="category-badge">{post.data.category}</span>
        <time datetime={post.data.updatedDate.toISOString()}>最終更新日: {formatDate(post.data.updatedDate)}</time>
      </div>
      
      <h1 class="post-title font-heading">{post.data.title}</h1>
      
      <div class="post-tags">
        {post.data.tags.map((tag) => (
          <span class="badge">#{tag}</span>
        ))}
      </div>
    </header>

    <!-- Markdown Content -->
    <div class="post-content glass-card prose">
      <Content />
    </div>

    <!-- Navigation Footer -->
    <footer class="post-footer">
      <a href="/wiki" class="back-link">&larr; Back to Wiki List</a>
    </footer>
  </article>
</Layout>

<style>
  .breadcrumb {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .breadcrumb a {
    color: var(--accent-blue);
  }

  .breadcrumb a:hover {
    color: var(--text-primary);
  }

  .post-header {
    margin-bottom: 32px;
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.95rem;
    color: var(--text-muted);
    margin-bottom: 12px;
    font-weight: 500;
  }

  .category-badge {
    background: var(--bg-tertiary);
    border: 1px solid var(--border-glow);
    color: var(--text-primary);
    padding: 2px 10px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.85rem;
  }

  .post-title {
    font-size: 2.2rem;
    line-height: 1.3;
    margin-bottom: 16px;
    color: var(--text-primary);
  }

  .post-tags {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  .post-content {
    padding: 30px;
    margin-bottom: 40px;
  }

  @media (min-width: 768px) {
    .post-content {
      padding: 40px;
    }
  }

  .post-footer {
    border-top: 1px solid var(--border-muted);
    padding-top: 24px;
  }

  .back-link {
    font-weight: 600;
    color: var(--accent-blue);
  }

  .back-link:hover {
    color: var(--text-primary);
    transform: translateX(-4px);
  }
</style>
