---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-container">
    <p class="copyright">
      &copy; {currentYear} <span class="gradient-text font-heading" style="font-weight:600;">kuroann.memo</span>. All rights reserved.
    </p>
    <div class="social-links">
      <a href="https://github.com/taiyakikuroann" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-github"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
      </a>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: auto;
    border-top: 1px solid var(--border-muted);
    background: rgba(10, 15, 30, 0.4);
    padding: 32px 0;
  }

  .footer-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .copyright {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .social-links {
    display: flex;
    gap: 16px;
  }

  .social-link {
    color: var(--text-muted);
    transition: var(--transition-smooth);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border-muted);
  }

  .social-link:hover {
    color: var(--text-primary);
    border-color: var(--accent-blue);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(190, 90, 60, 0.1);
  }
</style>
